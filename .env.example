# Copy this file to .env locally. Never publish your real token.
# You may also use a local-only alias if that PC has the matching
# PyAI_TOKEN_ALIASNAME environment variable or token_aliases.json configured privately.
PyAI_GITHUB_TOKEN=your_token_here
PyAI_MODEL=openai/gpt-4.1
PyAI_MAX_TOKENS=2600
PyAI_TEMPERATURE=0.1
PyAI_LANGUAGE=cpp
PyAI_SCREENSHOT_FALLBACK=1
PyAI_SELF_CHECK=1
PyAI_AI_REVIEW=0
# Optional: set a fixed folder. If blank, PyAI tries the current/recent VS Code folder.
PyAI_OUTPUT_DIR=
